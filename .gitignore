# Virtual Environment
backend/.venv/
.venv/
venv/
ENV/

# Env files (keep template files tracked)
backend/.env
.env
.env.*
!.env.example
!backend/.env.example
!frontend/.env.example

# Python
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
backend/.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/
.ipynb_checkpoints/

# Node / Frontend
node_modules/
frontend/node_modules/
frontend/.svelte-kit/
frontend/build/
dist/
out/
frontend/dist/
frontend/.env
frontend/.env.*
.eslintcache

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dev-only scratch and E2E artifacts
backend/scratch/
!backend/scratch/.gitkeep
frontend/test-results/
frontend/playwright-report/
testing-agent/reports/screenshots/

# IDEs and OS
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db

# Keep the frontend env template tracked (overrides frontend/.env.* above)
!frontend/.env.example
